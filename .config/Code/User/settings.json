{
    "editor.fontFamily": "PlemolJP Console NF Text",
    "editor.fontSize": 16,
    "editor.lineHeight": 1.5, // 行間
    "editor.wordWrap": "on",
    // エディタ体験
    "editor.smoothScrolling": true, // スクロールをスムーズに
    "editor.renderWhitespace": "boundary",
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active", // {}や[]を線でつなぐ
    "workbench.startupEditor": "none", // 起動時のウェルカム画面
    "window.zoomLevel": 1.2, // UIスケール
    "editor.mouseWheelZoom": true, // マウスホイールでズーム
    "editor.quickSuggestions": {
        "other": "on",
        "comments": "off",
        "strings": "on",
    },
    "workbench.editor.limit.enabled": true, // タブ数の制限 制限に達すると使用頻度の低いものを自動的に閉じる
    "workbench.editor.limit.value": 5, // タブ数の制限を5に設定
    "editor.cursorSmoothCaretAnimation": "on", // カーソルのアニメーションをスムーズにする
    "editor.cursorBlinking": "smooth", // 同上
    "window.openFilesInNewWindow": "default", // 新しいファイルを開くとき必ず新しいウィンドウで開く
    "window.openFoldersInNewWindow": "default", // 新しいフォルダを開くとき必ず新しいウィンドウで開く
    // 保存・フォーマット
    "editor.formatOnSave": true,
    "files.autoSave": "afterDelay",
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true, // 行末の余分なスペースを消す
    // Prettierの設定
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "prettier.printWidth": 100,
    "prettier.tabWidth": 4,
    "prettier.singleQuote": false,
    "prettier.bracketSpacing": true,
    "prettier.endOfLine": "auto",
    "extensions.ignoreRecommendations": true,

    // 他
    "window.commandCenter": false,
    "workbench.layoutControl.enabled": false,
    "security.workspace.trust.untrustedFiles": "open",
    // claudeCode
    "claudeCode.useTerminal": true,
    "explorer.confirmDelete": false,
    // NeoVim
    "vscode-neovim.NVIM_APPNAME": "nvim",
    "vscode-neovim.neovimExecutablePaths.linux": "/usr/bin/nvim",
    "vscode-neovim.neovimInitVimPaths.linux": "~/.config/nvim/init.lua",
    "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1,
    },
    "vim.useSystemClipboard": true,
    "vscode-neovim.logOutputToConsole": false,
    "vscode-neovim.neovimClean": true,
    // Git
    "git.autofetch": true,
    // 言語
    "files.associations": {
        "*.css": "tailwindcss",
    },
    "gitlens.rebaseEditor.ordering": "asc",
    "chat.disableAIFeatures": true,
    "vim.vimrc.path": "$HOME/.vimrc",
    // VSCodeでのvimの設定
    "editor.editContext": false,
    "vim.easymotion": true,
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": ["<space>"],
            "commands": ["vspacecode.space"],
        },
        {
            "before": [","],
            "commands": [
                "vspacecode.space",
                {
                    "command": "whichkey.triggerKey",
                    "args": "m",
                },
            ],
        },
        // // j(上移動)を見た目上の上移動にする
        // {
        //     "before": ["j"],
        //     "after": ["g", "j"],
        // },
        // // k(下移動)を見た目上の下移動にする
        // {
        //     "before": ["k"],
        //     "after": ["g", "k"],
        // },
        {
            // ":w"でprettierを動作させる
            "before": ["<leader>", "w"],
            "commands": ["workbench.action.files.save"],
        },
    ],
    "vim.visualModeKeyBindingsNonRecursive": [
        {
            "before": ["<space>"],
            "commands": ["vspacecode.space"],
        },
        {
            "before": [","],
            "commands": [
                "vspacecode.space",
                {
                    "command": "whichkey.triggerKey",
                    "args": "m",
                },
            ],
        },
        {
            "before": [">"],
            "commands": ["editor.action.indentLines"],
        },
        {
            "before": ["<"],
            "commands": ["editor.action.outdentLines"],
        },
    ],
    "js/ts.updateImportsOnFileMove.enabled": "always",
    "vim.vimrc.enable": true,
    "vim.highlightedyank.enable": true,
    "vim.hlsearch": true, // tailwindcssを使うときに、*.cssで@Ruleが使えない問題の対策
}
