{
    "workbench.startupEditor": "none",
    //"terminal.integrated.suggest.enabled": true,
    //"terminal.integrated.suggest.cdPath": "relative",
    //"terminal.integrated.suggest.inlineSuggestion": "alwaysOnTopExceptExactMatch",
    //"terminal.integrated.suggest.insertTrailingSpace": false,
    //"terminal.integrated.suggest.providers": { "lsp": false, },
    //"terminal.integrated.suggest.quickSuggestions": { "commands": "on", "arguments": "on", "unknown": "on" },
    //"terminal.integrated.suggest.suggestOnTriggerCharacters": false,
    //"terminal.integrated.suggest.selectionMode": "partial",
    //"terminal.integrated.suggest.runOnEnter": "always",
    "files.autoSave": "afterDelay",
    "window.commandCenter": false,
    "workbench.layoutControl.enabled": false,
    "claudeCode.preferredLocation": "panel",
    "claudeCode.useTerminal": true,
    "explorer.confirmDelete": false,
    "vscode-neovim.NVIM_APPNAME": "nvim",
    "vscode-neovim.neovimExecutablePaths.linux": "/usr/bin/nvim",
    "vscode-neovim.neovimInitVimPaths.linux": "~/.config/nvim/init.lua",
    "security.workspace.trust.untrustedFiles": "open",
    "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1,
    },
    // Prettierの設定
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "prettier.printWidth": 100,
    "prettier.tabWidth": 4,
    "prettier.singleQuote": false,
    "prettier.bracketSpacing": true,
    "prettier.endOfLine": "auto",
    "editor.fontFamily": "PlemolJP Console NF",
    "editor.mouseWheelZoom": true,
}
